# Copy to .env and fill in locally — never commit .env
ANTHROPIC_API_KEY=
# Recommended for Upstash (HTTPS, works on restrictive networks; also used for browser writes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternative: TCP URL from Upstash Connect tab (must be rediss://, full unmasked password)
REDIS_URL=
SENTRY_DSN=
DEEPGRAM_API_KEY=

# Sentry alert when live recall (or NAME recall) drops below this threshold (0–1)
RECALL_ALERT_THRESHOLD=0.75

# --- Observability (pick one at launch, or set OBSERVABILITY_TARGET=phoenix|ax) ---
# Local Phoenix (default) — launcher starts/stops Docker; manual: docker compose -f docker-compose.phoenix.yml up -d
OBSERVABILITY_TARGET=phoenix
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_PROJECT_NAME=immigration-redaction-demo
# Phoenix Cloud only (optional — leave blank for self-hosted Docker):
PHOENIX_API_KEY=

# Arize AX Cloud — set OBSERVABILITY_TARGET=ax or choose "Arize AX Cloud" in Launch Passage.app
# Get keys: https://app.arize.com → Settings → Space ID + API Key
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=immigration-redaction-demo
ARIZE_COLLECTOR_ENDPOINT=https://otlp.arize.com/v1/traces

# --- Redis Agent Memory (optional — voice multi-turn history, PII-free only) ---
# Create at: https://cloud.redis.io → Agent Memory → Quick create
AGENT_MEMORY_URL=
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=

# --- Redis LangCache (optional — semantic cache for voice FAQ) ---
# Create at: https://cloud.redis.io → LangCache → Quick create
LANGCACHE_URL=
LANGCACHE_CACHE_ID=
LANGCACHE_API_KEY=
