# Copy to .env and fill in locally — never commit .env
ANTHROPIC_API_KEY=
# Recommended for Upstash (HTTPS, works on restrictive networks; also used for Phase 2 browser writes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternative: TCP URL from Upstash Connect tab (must be rediss://, full unmasked password)
REDIS_URL=
SENTRY_DSN=
DEEPGRAM_API_KEY=

# --- Phase 5: Arize Phoenix (self-hosted — default) ---
# Start: docker compose -f docker-compose.phoenix.yml up -d
# UI:    http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_PROJECT_NAME=immigration-redaction-demo

# Phoenix Cloud only (optional — leave blank for self-hosted Docker):
PHOENIX_API_KEY=

# Legacy hosted Arize AX keys — NOT used by self-hosted Phoenix; leave blank:
ARIZE_API_KEY=
ARIZE_SPACE_KEY=
